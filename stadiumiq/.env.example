# StadiumIQ — AI layer configuration (F4)
# Copy this file to `.env` (or `.env.local`) and fill in real values.
# All AI config is read ONLY by lib/ai/env.ts (single source of truth,
# zod-validated, parsed once at load). NEVER commit a real key.

# Which provider adapter to use. Supported: "gemini" | "groq".
LLM_PROVIDER=gemini

# Model id for the selected provider (no model name is hardcoded in source).
#   gemini example: gemini-2.5-flash
#   groq example:   llama-3.3-70b-versatile
LLM_MODEL=your-model-id

# Provider API key.
LLM_API_KEY=your-api-key-here

# Per-provider-request timeout in milliseconds (optional; defaults to 8000).
LLM_TIMEOUT_MS=8000
